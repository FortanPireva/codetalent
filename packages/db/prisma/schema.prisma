generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enums
enum Role {
  ADMIN
  CANDIDATE
  CLIENT
}

enum Availability {
  ACTIVELY_LOOKING
  OPEN_TO_OFFERS
  NOT_LOOKING
  HIRED
}

enum Difficulty {
  INTERN
  JUNIOR
  MID
}

enum SubmissionStatus {
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  UNDER_REVIEW
  PASSED
  REJECTED
}

enum CandidateStatus {
  ONBOARDING
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum ClientOnboardingStatus {
  ONBOARDING
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum CompanySize {
  STARTUP
  SMB
  ENTERPRISE
}

enum ClientStatus {
  LEAD
  ACTIVE
  CHURNED
}

enum JobStatus {
  DRAFT
  OPEN
  PAUSED
  FILLED
  CLOSED
  EXPIRED
}

enum ExperienceLevel {
  INTERN
  JUNIOR
  MID
  SENIOR
  STAFF
  PRINCIPAL
  LEAD
  MANAGER
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
}

enum WorkArrangement {
  ONSITE
  HYBRID
  REMOTE_LOCAL
  REMOTE_GLOBAL
}

enum JobUrgency {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ApplicationStatus {
  APPLIED
  INVITED
  INTERVIEW
  HIRED
  REJECTED
}

enum SubscriptionTier {
  STARTER
  GROWTH
  SCALE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

// Models
model User {
  id           String       @id @default(cuid())
  email        String       @unique
  password     String
  name         String?
  role         Role         @default(CANDIDATE)
  availability Availability @default(ACTIVELY_LOOKING)
  bio          String?
  skills       String[]
  githubUrl    String?
  linkedinUrl  String?
  resumeUrl    String?
  profilePicture String?
  phone        String?
  location     String?
  candidateStatus CandidateStatus @default(ONBOARDING)
  rejectionReason String?
  passwordResetToken  String?   @unique
  passwordResetExpiry DateTime?
  clientStatus          ClientOnboardingStatus @default(ONBOARDING)
  clientRejectionReason String?
  hourlyRate    Float?
  monthlyRate   Float?
  rateCurrency  String   @default("USD")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  submissions     Submission[]
  client          Client?
  jobApplications JobApplication[]

  @@index([role])
  @@index([availability])
  @@index([candidateStatus])
  @@index([clientStatus])
  @@index([hourlyRate])
  @@index([createdAt])
}

model Assessment {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  description String
  difficulty  Difficulty
  repoUrl     String
  timeLimit   Int        @default(7) // days
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  submissions Submission[]

  @@index([slug])
  @@index([isActive])
  @@index([difficulty])
}

model Submission {
  id           String           @id @default(cuid())
  status       SubmissionStatus @default(ASSIGNED)
  forkUrl      String?
  startedAt    DateTime?
  submittedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessmentId String
  assessment   Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  review       Review?

  @@unique([userId, assessmentId])
  @@index([status])
  @@index([userId])
  @@index([assessmentId])
  @@index([createdAt])
}

model Review {
  id              String   @id @default(cuid())
  codeQuality     Float
  architecture    Float
  typeSafety      Float
  errorHandling   Float
  testing         Float
  gitPractices    Float
  documentation   Float
  bestPractices   Float
  averageScore    Float
  passed          Boolean
  summary         String
  strengths       String[]
  improvements    String[]
  createdAt       DateTime @default(now())

  submissionId    String   @unique
  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([passed])
  @@index([averageScore])
  @@index([createdAt])
}

model Client {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  logo         String?
  website      String?
  description  String
  industry     String
  size         CompanySize
  location     String
  techStack    String[]
  contactName  String
  contactEmail String
  status       ClientStatus @default(LEAD)
  notes        String?
  userId       String?      @unique
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  jobs         Job[]
  subscription ClientSubscription?

  @@index([status])
  @@index([industry])
  @@index([createdAt])
}

model ClientSubscription {
  id                  String             @id @default(cuid())
  tier                SubscriptionTier
  billingInterval     BillingInterval
  status              SubscriptionStatus @default(ACTIVE)
  activeJobPostLimit  Int                @default(3)
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  cancelledAt         DateTime?
  externalCustomerId  String?
  externalSubId       String?
  clientId            String             @unique
  client              Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@index([status])
  @@index([currentPeriodEnd])
}

model Job {
  id              String          @id @default(cuid())
  title           String
  slug            String          @unique
  status          JobStatus       @default(DRAFT)
  summary         String?
  description     String?         @db.Text
  responsibilities String?        @db.Text
  requirements    String?         @db.Text
  niceToHave      String?         @db.Text

  // Role
  roleType        String?
  experienceLevel ExperienceLevel?
  yearsMin        Int?
  yearsMax        Int?

  // Tech
  requiredSkills  String[]
  preferredSkills String[]
  techStack       String[]
  frameworks      String[]
  databases       String[]
  cloud           String[]
  tools           String[]

  // Employment
  employmentType  EmploymentType?
  workArrangement WorkArrangement?
  location        String?
  timezone        String?
  relocation      Boolean         @default(false)
  visaSponsorship Boolean         @default(false)

  // Compensation
  showSalary      Boolean         @default(true)
  salaryMin       Int?
  salaryMax       Int?
  salaryCurrency  String          @default("USD")
  salaryPeriod    String          @default("YEARLY")
  equity          Boolean         @default(false)
  equityRange     String?
  bonus           String?
  benefits        String[]

  // Interview
  interviewStages String[]
  interviewLength String?

  // Hiring
  urgency         JobUrgency      @default(MEDIUM)
  headcount       Int             @default(1)
  filledCount     Int             @default(0)
  startsAt        DateTime?
  closesAt        DateTime?
  publishedAt     DateTime?

  // Metrics
  viewCount       Int             @default(0)
  applicationCount Int            @default(0)

  // SEO
  tags            String[]
  featured        Boolean         @default(false)

  // Relations
  clientId        String
  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  applications    JobApplication[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status])
  @@index([clientId])
  @@index([slug])
  @@index([experienceLevel])
  @@index([employmentType])
  @@index([workArrangement])
  @@index([createdAt])
}

model JobApplication {
  id          String            @id @default(cuid())
  status      ApplicationStatus @default(APPLIED)
  coverLetter String?           @db.Text
  appliedAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
  @@index([jobId])
  @@index([status])
  @@index([appliedAt])
}
