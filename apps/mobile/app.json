{
  "expo": {
    "name": "Talentflow",
    "slug": "talentflow-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "net.codeks.talentflow",
    "splash": {
      "image": "./assets/splash-light.png",
      "resizeMode": "cover",
      "backgroundColor": "#f4f3ef",
      "dark": {
        "image": "./assets/splash-dark.png",
        "resizeMode": "cover",
        "backgroundColor": "#141414"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "net.codeks.talentflow",
      "icon": {
        "light": "./assets/icon.png",
        "dark": "./assets/icon-dark.png",
        "tinted": "./assets/icon-tinted.png"
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "975704495002-6720hvdr9bgirh4c7v48bdv6pk5j7ijo.apps.googleusercontent.com  "
            ]
          }
        ]
      },
      "appleTeamId": "K68DXPQN8U"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "net.codeks.talentflow"
    },
    "plugins": [
      "./plugins/withAsyncStorageLocalRepo",
      "expo-system-ui",
      "expo-router",
      "expo-secure-store",
      "expo-splash-screen",
      "expo-font",
      "expo-document-picker",
      "expo-apple-authentication",
      "@react-native-google-signin/google-signin",
      [
        "expo-notifications",
        {
          "sounds": []
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2820e468-7ebd-4193-be82-b334ec1c6c13"
      }
    }
  }
}