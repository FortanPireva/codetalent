{
  "name": "codetalent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @codetalent/web dev",
    "dev:mobile": "pnpm --filter @codetalent/mobile start",
    "dev:all": "pnpm -r --parallel dev",
    "build": "pnpm --filter @codetalent/web build",
    "lint": "pnpm --filter @codetalent/web lint",
    "db:generate": "pnpm --filter @codetalent/db db:generate",
    "db:push": "pnpm --filter @codetalent/db db:push",
    "db:studio": "pnpm --filter @codetalent/db db:studio",
    "db:seed": "pnpm --filter @codetalent/db db:seed",
    "db:reset": "pnpm --filter @codetalent/db db:reset"
  }
}
